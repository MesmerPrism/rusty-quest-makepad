{
  "schema": "rusty.quest.runtime_profile.v1",
  "profile_id": "profile.quest.makepad.mesh_replay",
  "target_platform": "quest",
  "owned_android_properties": [
    "debug.rustyquest.makepad.mesh.replay.enabled",
    "debug.rustyquest.makepad.mesh.replay.speed",
    "debug.rustyquest.makepad.mesh.replay.opacity",
    "debug.rustyquest.makepad.render.scale",
    "debug.rustyquest.makepad.collision.enabled",
    "debug.rustyquest.makepad.sdf_adf.overlay_mode",
    "debug.rustyquest.makepad.particles.enabled"
  ],
  "set_properties": [
    {
      "name": "debug.rustyquest.makepad.mesh.replay.enabled",
      "value": "true",
