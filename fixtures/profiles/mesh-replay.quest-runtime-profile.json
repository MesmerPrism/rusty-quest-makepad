    },
    {
      "name": "debug.rustyquest.makepad.render.scale",
      "value": "0.9",
      "source_setting_id": "makepad.render.scale"
    },
    {
      "name": "debug.rustyquest.makepad.collision.enabled",
      "value": "false",
      "source_setting_id": "makepad.collision.enabled"
    },
    {
      "name": "debug.rustyquest.makepad.sdf_adf.overlay_mode",
      "value": "off",
      "source_setting_id": "makepad.sdf_adf.overlay_mode"
    },
    {
      "name": "debug.rustyquest.makepad.particles.enabled",
      "value": "false",
      "source_setting_id": "makepad.particles.enabled"
    }
  ],
  "expected_markers": [
    "RUSTY_QUEST_MAKEPAD_EFFECTIVE_SETTINGS"
  ],
  "validation_commands": [
    "powershell -NoProfile -ExecutionPolicy Bypass -File tools/Test-QuestMakepadProfiles.ps1"
  ]
